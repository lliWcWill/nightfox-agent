{
  "name": "nightfox",
  "version": "1.0.0",
  "description": "Telegram bot that bridges messages to Claude Code with full agent capabilities",
  "type": "module",
  "main": "dist/index.js",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "discord": "tsx watch src/discord-index.ts",
    "discord:start": "node dist/discord-index.js",
    "dashboard:dev": "node scripts/run-dashboard-workspace.mjs dev",
    "dashboard:build": "node scripts/run-dashboard-workspace.mjs build",
    "dashboard:start": "node scripts/run-dashboard-workspace.mjs start",
    "dashboard:lint": "node scripts/run-dashboard-workspace.mjs lint",
    "smoke:jobs": "tsx scripts/portable-jobs-smoke.ts",
    "smoke:phase3": "tsx scripts/jobs-phase3-smoke.ts"
  },
  "keywords": [
    "telegram",
    "claude",
    "bot",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.1",
    "@google/genai": "^1.44.0",
    "@grammyjs/runner": "^2.0.3",
    "@openai/agents": "^0.6.0",
    "@snazzah/davey": "^0.1.10",
    "@types/turndown": "^5.0.6",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "mathjs": "^15.1.0",
    "openai": "^6.27.0",
    "prism-media": "^1.3.5",
    "sodium-native": "^5.1.0",
    "telegra.ph": "^1.0.1",
    "telegram-markdown-v2": "^0.0.4",
    "turndown": "^7.2.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  }
}
